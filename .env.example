# ThirtyDays - Environment Variables
# Copy this to .env and fill in your values

# Flask
SECRET_KEY=change-this-to-a-random-secret-key
FLASK_ENV=development

# Email (SMTP) — for milestone reminder emails
# Without these, emails print to console instead of sending
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-app-password
FROM_NAME=ThirtyDays
FROM_EMAIL=hello@thirtydays.app

# Google Calendar OAuth — enables auto-creating deadline events
# Create at: https://console.cloud.google.com/apis/credentials
# Enable: Google Calendar API
# Add OAuth redirect URI: http://localhost:5000/calendar/callback (dev)
#                                  https://thirtydays.app/calendar/callback (prod)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/calendar/callback